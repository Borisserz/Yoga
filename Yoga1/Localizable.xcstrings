    "pose.pigeon.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From all fours, bring one knee forward behind your wrist."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Из положения на четвереньках выведите одно колено вперёд за запястье."
          }
        }
      }
    },
    "pose.pigeon.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extend the other leg straight back behind you."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вытяните другую ногу прямо назад."
          }
        }
      }
