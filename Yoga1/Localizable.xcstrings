    "med.deep_calm.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settle into deep stillness at your own pace."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Погрузись в глубокую тишину в своём темпе."
          }
        }
      }
    },
    "med.morning_intention.s1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settle in and take three slow breaths. A new day is beginning."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устройся удобно и сделай три медленных вдоха. Начинается новый день."
          }
        }
      }
    },
    "med.morning_intention.s2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feel your body waking up. Notice the gentle weight of being here, now."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Почувствуй, как тело просыпается. Ощути мягкое присутствие здесь и сейчас."
          }
        }
      }
    },
    "med.morning_intention.s3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring to mind one intention for today. How do you want to feel?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вспомни одно намерение на сегодня. Как ты хочешь себя чувствовать?"
          }
        }
      }
    },
    "med.morning_intention.s4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Picture yourself moving through the day with that intention, calm and steady."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Представь, как проживаешь день с этим намерением — спокойно и уверенно."
          }
        }
      }
    },
    "med.morning_intention.s5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Carry this calm with you. When you're ready, gently open your eyes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Унеси этот покой с собой. Когда будешь готов(а), мягко открой глаза."
          }
        }
      }
    },
    "med.breath_awareness.s1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sit comfortably and let your spine grow tall. Soften your shoulders."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сядь удобно, вытяни позвоночник. Расслабь плечи."
          }
        }
      }
    },
    "med.breath_awareness.s2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring your attention to your breath. Don't change it — just notice it."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перенеси внимание на дыхание. Не меняй его — просто наблюдай."
          }
        }
      }
    },
    "med.breath_awareness.s3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow the air as it flows in… and as it flows out."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Следи за воздухом на вдохе… и на выдохе."
          }
        }
      }
    },
    "med.breath_awareness.s4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When your mind wanders, that's okay. Gently return to the breath."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если мысли уплыли — это нормально. Мягко вернись к дыханию."
          }
        }
      }
    },
    "med.breath_awareness.s5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rest here in this steady awareness for a few more breaths."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Побудь в этом ровном осознании ещё несколько вдохов."
          }
        }
      }
    },
    "med.body_scan.s1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie down and let your whole body grow heavy. Close your eyes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ляг и позволь телу стать тяжёлым. Закрой глаза."
          }
        }
      }
    },
    "med.body_scan.s2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring your attention to your feet. Let them soften and release."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перенеси внимание на стопы. Дай им расслабиться и отпустить."
          }
        }
      }
    },
    "med.body_scan.s3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move up to your legs and hips. Let go of any holding."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимись к ногам и бёдрам. Отпусти всё напряжение."
          }
        }
      }
    },
    "med.body_scan.s4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Soften your belly, chest, and back. Breathe slowly."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расслабь живот, грудь и спину. Дыши медленно."
          }
        }
      }
    },
    "med.body_scan.s5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Release your shoulders, arms, and hands. Let them melt."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отпусти плечи, руки и кисти. Пусть они растают."
          }
        }
      }
    },
    "med.body_scan.s6": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Soften your face and jaw. Let your whole body rest completely."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расслабь лицо и челюсть. Дай всему телу полностью отдохнуть."
          }
        }
      }
    },
    "med.loving_kindness.s1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settle in and bring a soft smile to your face."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устройся удобно и позволь лёгкой улыбке появиться на лице."
          }
        }
      }
    },
    "med.loving_kindness.s2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring to mind someone you love. Silently wish them: may you be happy."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вспомни того, кого любишь. Молча пожелай: будь счастлив(а)."
          }
        }
      }
    },
    "med.loving_kindness.s3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Now offer the same to yourself: may I be happy, may I be at ease."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Теперь пожелай это себе: пусть я буду счастлив(а) и спокоен(йна)."
          }
        }
      }
    },
    "med.loving_kindness.s4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extend it wider: may all beings be safe, may all beings be free."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расширь шире: пусть все существа будут в безопасности и свободны."
          }
        }
      }
    },
    "med.loving_kindness.s5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rest in this warmth and kindness. Let it fill you."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Побудь в этом тепле и доброте. Дай им наполнить тебя."
          }
        }
      }
    },
    "med.anxiety_grounding.s1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take one slow breath. You are safe in this moment."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сделай один медленный вдох. В этот момент ты в безопасности."
          }
        }
      }
    },
    "med.anxiety_grounding.s2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notice five things you can see around you."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заметь пять вещей, которые ты видишь вокруг."
          }
        }
      }
    },
    "med.anxiety_grounding.s3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notice four things you can feel — your seat, your hands, the air."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заметь четыре ощущения — опору, руки, воздух."
          }
        }
      }
    },
    "med.anxiety_grounding.s4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notice three things you can hear, near and far."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заметь три звука — близкие и далёкие."
          }
        }
      }
    },
    "med.anxiety_grounding.s5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a long exhale. The wave has passed. You are here."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сделай длинный выдох. Волна прошла. Ты здесь."
          }
        }
      }
    },
    "med.stress_release.s1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sit comfortably and take a deep breath in… and a long sigh out."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сядь удобно, глубоко вдохни… и с долгим выдохом отпусти."
          }
        }
      }
    },
    "med.stress_release.s2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan for any tension. Where are you holding stress today?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Найди напряжение. Где сегодня прячется стресс?"
          }
        }
      }
    },
    "med.stress_release.s3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe into that area. With each exhale, let a little go."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подыши в это место. С каждым выдохом отпускай понемногу."
          }
        }
      }
    },
    "med.stress_release.s4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drop your shoulders. Unclench your jaw. Soften your hands."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опусти плечи. Расслабь челюсть. Смягчи кисти."
          }
        }
      }
    },
    "med.stress_release.s5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feel lighter now. Carry this ease into the rest of your day."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Почувствуй лёгкость. Унеси её в остаток дня."
          }
        }
      }
    },
    "med.timer.prompt": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe gently and let your thoughts drift by."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дыши мягко и позволь мыслям проплывать мимо."
          }
        }
      }
    },
    "achievement.zen": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Inner Peace"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Внутренний покой"
          }
        }
      }
    },
