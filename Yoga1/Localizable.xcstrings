    },
    "pose.triangle.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extend the top arm straight up, stacking the shoulders."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
