    "pose.half_moon.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place your front hand on the floor a foot ahead."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поставьте переднюю руку на пол на расстоянии стопы впереди."
          }
