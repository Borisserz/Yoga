    "pose.camel.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift your chest and gently arch backward."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимите грудь и мягко прогнитесь назад."
          }
        }
      }
    },
    "pose.camel.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reach your hands toward your heels if it feels safe."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
