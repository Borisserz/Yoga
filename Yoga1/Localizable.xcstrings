    "pose.camel.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kneel with your knees hip-width apart, shins on the mat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте на колени на ширине таза, голени на коврике."
