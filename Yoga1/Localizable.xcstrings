    },
    "pose.triangle.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reach forward and lower your front hand to your shin or the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Потянитесь вперёд и опустите переднюю руку на голень или пол."
