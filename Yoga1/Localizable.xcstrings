    },
    "pose.triangle.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn your gaze toward the top hand."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
