    },
    "pose.camel.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your neck long and breathe into the chest."
          }
        },
        "ru": {
          "stringUnit": {
