    "pose.seated_twist.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Inhale and lengthen your spine tall."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На вдохе вытяните позвоночник вверх."
          }
        }
      }
    },
    "pose.seated_twist.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exhale and twist toward the bent knee."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На выдохе скрутитесь в сторону согнутого колена."
          }
        }
      }
    },
    "pose.seated_twist.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hook your elbow outside the knee for leverage."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заведите локоть за колено для опоры."
          }
        }
