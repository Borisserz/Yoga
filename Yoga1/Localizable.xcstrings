    "pose.cat_cow.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spine mobility"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подвижность спины"
          }
        }
      }
    },
    "pose.cat_cow.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I flow"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я теку"
          }
        }
      }
    },
    "pose.cat_cow.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Come onto all fours, wrists under shoulders, knees under hips."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте на четвереньки, запястья под плечами, колени под тазом."
          }
        }
      }
    },
    "pose.cat_cow.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Inhale: drop your belly, lift your chest and tailbone (cow)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вдох: прогнитесь, поднимите грудь и копчик (корова)."
          }
        }
      }
    },
    "pose.cat_cow.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exhale: round your spine and tuck your chin (cat)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выдох: округлите спину и подтяните подбородок (кошка)."
          }
        }
      }
    },
    "pose.cat_cow.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move slowly, linking each movement to your breath."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Двигайтесь медленно, связывая движение с дыханием."
          }
        }
      }
    },
    "pose.cat_cow.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your arms straight and shoulders steady."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держите руки прямыми, плечи стабильными."
          }
        }
      }
    },
    "pose.seated_forward_bend.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Seated Forward Bend"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Наклон сидя"
          }
