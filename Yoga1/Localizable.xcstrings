    },
    "pose.half_moon.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open your hips and stack your top arm upward."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Раскройте таз и вытяните верхнюю руку вверх."
