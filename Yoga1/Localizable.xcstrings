    "pose.half_moon.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From a lunge, shift weight onto your front foot."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Из выпада перенесите вес на переднюю стопу."
