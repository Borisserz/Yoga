    },
    "pose.seated_forward_bend.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hamstrings"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задняя поверхность бедра"
          }
        }
      }
    },
    "pose.seated_forward_bend.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I let go"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я отпускаю"
          }
        }
      }
    },
    "pose.seated_forward_bend.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sit with your legs extended straight in front of you."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сядьте, вытянув ноги прямо перед собой."
          }
        }
      }
    },
    "pose.seated_forward_bend.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Inhale and lengthen your spine upward."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На вдохе вытяните позвоночник вверх."
          }
        }
      }
    },
    "pose.seated_forward_bend.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exhale and hinge forward from the hips."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На выдохе наклонитесь вперёд от тазобедренных суставов."
          }
        }
      }
    },
    "pose.seated_forward_bend.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reach for your shins, ankles, or feet without rounding."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Возьмитесь за голени, лодыжки или стопы, не округляя спину."
          }
        }
      }
    },
    "pose.seated_forward_bend.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Relax your neck and breathe into the stretch."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расслабьте шею и дышите в растяжение."
          }
        }
      }
    },
    "pose.plank.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plank"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Планка"
          }
        }
      }
    },
    "pose.plank.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Core"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кор"
          }
        }
      }
    },
    "pose.plank.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am strong"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я силён"
          }
        }
      }
    },
    "pose.plank.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From all fours, step your feet back to a straight line."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Из положения на четвереньках отшагните стопы назад в прямую линию."
          }
        }
      }
    },
    "pose.plank.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stack your shoulders directly over your wrists."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плечи строго над запястьями."
          }
        }
      }
    },
    "pose.plank.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Engage your core and draw your belly in."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Напрягите кор, подтяните живот."
          }
        }
      }
    },
    "pose.plank.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your hips level with your shoulders."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держите таз на уровне плеч."
          }
        }
      }
    },
    "pose.plank.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press the floor away and breathe evenly."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отталкивайтесь от пола и ровно дышите."
          }
        }
      }
    },
    "pose.pigeon.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pigeon"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поза Голубя"
          }
