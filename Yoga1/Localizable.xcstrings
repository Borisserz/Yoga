    },
    "pose.pigeon.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hip opener"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Раскрытие бёдер"
          }
        }
      }
