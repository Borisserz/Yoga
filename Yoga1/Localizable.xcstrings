{
  "sourceLanguage": "en",
  "strings": {
    "Step fully into the frame": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step fully into the frame"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте полностью в кадр"
          }
        }
      }
    },
    "Lift one leg and place the foot on your inner thigh": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift one leg and place the foot on your inner thigh"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимите одну ногу и поставьте её на внутреннюю часть бедра"
          }
        }
      }
    },
    "Bend your lifted leg more": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend your lifted leg more"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Согните поднятую ногу сильнее"
          }
        }
      }
    },
    "Straighten your standing leg": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Straighten your standing leg"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпрямите опорную ногу"
          }
        }
      }
    },
    "Great! Hold your balance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Great! Hold your balance."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отлично! Держите баланс."
          }
        }
      }
    },
    "Turn sideways to the camera": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn sideways to the camera"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте боком к камере"
          }
        }
      }
    },
    "Lift your hips higher to sharpen the angle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift your hips higher to sharpen the angle"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимите таз выше, сделайте угол острее"
          }
        }
      }
    },
    "Widen your stance, the angle is too sharp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Widen your stance, the angle is too sharp"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разойдитесь шире, угол слишком острый"
          }
        }
      }
    },
    "Straighten your arms and lengthen your back": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Straighten your arms and lengthen your back"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпрямите руки и вытяните спину"
          }
        }
      }
    },
    "Perfect downward dog!": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Perfect downward dog!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Идеальная собака мордой вниз!"
          }
        }
      }
    },
    "Straighten your knees": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Straighten your knees"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпрямите колени"
          }
        }
      }
    },
    "Bring your feet closer together": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring your feet closer together"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сведите стопы ближе"
          }
        }
      }
    },
    "Straighten your back and open your shoulders": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Straighten your back and open your shoulders"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпрямите спину и расправьте плечи"
          }
        }
      }
    },
    "Great, hold mountain pose!": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Great, hold mountain pose!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отлично, держите позу горы!"
          }
        }
      }
    },
    "Sit lower, bend your knees": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sit lower, bend your knees"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Присядьте ниже, согните колени"
          }
        }
      }
    },
    "Don't squat so deep": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't squat so deep"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не приседайте так глубоко"
          }
        }
      }
    },
    "Lift your chest, don't lean too far forward": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift your chest, don't lean too far forward"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимите грудь, не наклоняйтесь слишком сильно"
          }
        }
      }
    },
    "Raise your arms overhead": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Raise your arms overhead"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимите руки вверх"
          }
        }
      }
    },
    "Powerful pose! Hold it!": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Powerful pose! Hold it!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мощная поза! Держим!"
          }
        }
      }
    },
    "Step fully into the frame, sideways": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step fully into the frame, sideways"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте полностью в кадр боком"
          }
        }
      }
    },
    "Step your feet wider apart": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step your feet wider apart"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расставьте ноги шире"
          }
        }
      }
    },
    "Straighten your back leg": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Straighten your back leg"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпрямите заднюю ногу"
          }
        }
      }
    },
    "Bend your front knee more": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend your front knee more"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Согните переднее колено сильнее"
          }
        }
      }
    },
    "Your front knee angle is too sharp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your front knee angle is too sharp"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Угол переднего колена слишком острый"
          }
        }
      }
    },
    "Keep your arms parallel to the floor": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your arms parallel to the floor"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держите руки параллельно полу"
          }
        }
      }
    },
    "Beautiful Warrior II!": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Beautiful Warrior II!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прекрасный Воин II!"
          }
        }
      }
    },
    "The camera must see your full body from the side": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The camera must see your full body from the side"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Камера должна видеть вас сбоку целиком"
          }
        }
      }
    },
    "Lift your feet off the floor": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift your feet off the floor"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оторвите стопы от пола"
          }
        }
      }
    },
    "Draw your knees higher toward your armpits": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Draw your knees higher toward your armpits"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подтяните колени выше к подмышкам"
          }
        }
      }
    },
    "Great balance! You're flying!": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Great balance! You're flying!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отличный баланс! Вы летите!"
          }
        }
      }
    },
    "Lie down on the mat, sideways to the camera": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie down on the mat, sideways to the camera"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опуститесь на коврик боком к камере"
          }
        }
      }
    },
    "Lower your hips onto your heels": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower your hips onto your heels"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опустите таз на пятки"
          }
        }
      }
    },
    "Bring your chest and forehead to the mat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring your chest and forehead to the mat"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опустите грудь и лоб на коврик"
          }
        }
      }
    },
    "Breathe deeply. You are calm.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe deeply. You are calm."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дышите глубоко. Вы спокойны."
          }
        }
      }
    },
    "Step into frame": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step into frame"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте в кадр"
          }
        }
      }
    },
    "Tracking your pose...": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tracking your pose..."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Следим за позой..."
          }
        }
      }
    },
    "pose.warrior_ii.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warrior Flow"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поза Потока 1"
          }
        }
      }
    },
    "pose.warrior_ii.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leg strength"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сила ног"
          }
        }
      }
    },
    "pose.warrior_ii.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I hold my balance"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я держу баланс"
          }
        }
      }
    },
    "pose.warrior_ii.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step your feet wide apart (about one meter)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Широко расставьте ноги (примерно 1 метр)."
          }
        }
      }
    },
    "pose.warrior_ii.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn your right foot 90 degrees outward."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поверните правую стопу на 90 градусов наружу."
          }
        }
      }
    },
    "pose.warrior_ii.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend your right knee so it sits directly above the ankle."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Согните правое колено так, чтобы оно было ровно над лодыжкой."
          }
        }
      }
    },
    "pose.warrior_ii.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extend your arms out to the sides, parallel to the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вытяните руки в стороны параллельно полу."
          }
        }
      }
    },
    "pose.warrior_ii.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaze over the fingers of your right hand. Keep your back straight."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смотрите поверх пальцев правой руки. Спина прямая."
          }
        }
      }
    },
    "pose.tadasana.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mountain Strength"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сила Гор 2"
          }
        }
      }
    },
    "pose.tadasana.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Posture"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Осанка"
          }
        }
      }
    },
    "pose.tadasana.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am like a mountain"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я как гора"
          }
        }
      }
    },
    "pose.tadasana.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand tall, feet together or hip-width apart."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте прямо, стопы вместе или на ширине таза."
          }
        }
      }
    },
    "pose.tadasana.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Distribute your weight evenly across each foot."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Распределите вес равномерно по всей стопе."
          }
        }
      }
    },
    "pose.tadasana.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Engage your knees and level your pelvis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подтяните колени и выровняйте таз."
          }
        }
      }
    },
    "pose.tadasana.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Roll your shoulders down and back, opening your chest."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опустите плечи вниз и назад, раскройте грудную клетку."
          }
        }
      }
    },
    "pose.tadasana.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Arms rest by your sides or reach overhead. Lengthen the crown of your head toward the sky."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Руки опущены вдоль тела или вытянуты вверх. Макушкой тянитесь в небо."
          }
        }
      }
    },
    "pose.bakasana.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dragon Flight"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Полет Дракона 3"
          }
        }
      }
    },
    "pose.bakasana.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Arm balance"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Баланс на руках"
          }
        }
      }
    },
    "pose.bakasana.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am flying"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я лечу"
          }
        }
      }
    },
    "pose.bakasana.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Squat down and place your palms on the floor shoulder-width apart."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сядьте на корточки, поставьте ладони на пол перед собой на ширине плеч."
          }
        }
      }
    },
    "pose.bakasana.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend your elbows slightly."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слегка согните руки в локтях."
          }
        }
      }
    },
    "pose.bakasana.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift your hips and rest your knees high on your upper arms, close to the armpits."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оторвите таз от пола и упритесь коленями в верхнюю часть рук (ближе к подмышкам)."
          }
        }
      }
    },
    "pose.bakasana.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shift your body weight forward onto your hands."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перенесите вес тела вперед на руки."
          }
        }
      }
    },
    "pose.bakasana.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Slowly lift your feet off the floor, balancing on your palms."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Постепенно оторвите стопы от пола, балансируя на ладонях."
          }
        }
      }
    },
    "pose.balasana.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quiet Ocean"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тихий океан 4"
          }
        }
      }
    },
    "pose.balasana.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recovery"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Восстановление"
          }
        }
      }
    },
    "pose.balasana.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am calm"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я спокоен"
          }
        }
      }
    },
    "pose.balasana.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kneel down and lower your hips onto your heels."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сядьте на колени, таз опустите на пятки."
          }
        }
      }
    },
    "pose.balasana.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fold forward and rest your forehead on the mat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Наклонитесь вперед, положив лоб на коврик."
          }
        }
      }
    },
    "pose.balasana.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stretch your arms far forward or let them rest alongside your body."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Руки вытяните далеко вперед перед собой или опустите вдоль тела."
          }
        }
      }
    },
    "pose.balasana.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Relax your neck, shoulders, and back."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расслабьте шею, плечи и спину."
          }
        }
      }
    },
    "pose.balasana.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe deeply, feeling your spine lengthen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дышите глубоко, чувствуя растяжение позвоночника."
          }
        }
      }
    },
    "pose.utkatasana.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fireball"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Огненный шар 5"
          }
        }
      }
    },
    "pose.utkatasana.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Endurance"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выносливость"
          }
        }
      }
    },
    "pose.utkatasana.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Energy is within me"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Энергия во мне"
          }
        }
      }
    },
    "pose.utkatasana.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand tall with your feet together."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте прямо, стопы вместе."
          }
        }
      }
    },
    "pose.utkatasana.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On an inhale, raise your straight arms overhead."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На вдохе поднимите прямые руки вверх."
          }
        }
      }
    },
    "pose.utkatasana.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On an exhale, bend your knees and lower your hips as if sitting on an invisible chair."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На выдохе согните колени и опустите таз вниз, словно садитесь на невидимый стул."
          }
        }
      }
    },
    "pose.utkatasana.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make sure your knees don't extend far past your toes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Следите, чтобы колени не выходили далеко за носки."
          }
        }
      }
    },
    "pose.utkatasana.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your back straight, chest open, and gaze forward."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Спина прямая, грудь раскрыта, взгляд направлен вперед."
          }
        }
      }
    },
    "pose.vrksasana.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tree of Life"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дерево Жизни 6"
          }
        }
      }
    },
    "pose.vrksasana.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Balance"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Равновесие"
          }
        }
      }
    },
    "pose.vrksasana.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am putting down roots"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я пускаю корни"
          }
        }
      }
    },
    "pose.vrksasana.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand tall. Shift your weight onto your left leg."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте прямо. Перенесите вес на левую ногу."
          }
        }
      }
    },
    "pose.vrksasana.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend your right leg and place the foot on your inner left thigh (or calf, but never on the knee)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Согните правую ногу и положите стопу на внутреннюю часть левого бедра (или голени, но не на колено!)."
          }
        }
      }
    },
    "pose.vrksasana.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open your right knee out to the side, opening the hip."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отведите правое колено в сторону, раскрывая таз."
          }
        }
      }
    },
    "pose.vrksasana.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring your palms together at your chest or raise them overhead."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сложите ладони перед грудью или поднимите их над головой."
          }
        }
      }
    },
    "pose.vrksasana.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fix your gaze on a still point ahead to keep your balance."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Найдите неподвижную точку перед собой для баланса."
          }
        }
      }
    },
    "pose.downward_dog.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Downward Dog"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Собака мордой вниз 7"
          }
        }
      }
    },
    "pose.downward_dog.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Back stretch"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Растяжка спины"
          }
        }
      }
    },
    "pose.downward_dog.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I am open to the world"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я открыт миру"
          }
        }
      }
    },
    "pose.downward_dog.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Come onto all fours, hands under shoulders, knees under hips."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встаньте на четвереньки, ладони под плечами, колени под тазом."
          }
        }
      }
    },
    "pose.downward_dog.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press your hands into the mat and lift your hips up and back."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оттолкнитесь руками от коврика, поднимите таз вверх и назад."
          }
        }
      }
    },
    "pose.downward_dog.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Straighten your arms and back into one long line."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпрямите руки и спину, образуя ровную линию."
          }
        }
      }
    },
    "pose.downward_dog.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try to straighten your knees and lower your heels (or keep the knees slightly bent)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Постарайтесь выпрямить колени и опустить пятки на пол (или держите колени слегка согнутыми)."
          }
        }
      }
    },
    "pose.downward_dog.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Relax your neck and gaze toward your feet."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расслабьте шею, смотрите на свои стопы."
          }
        }
      }
    },
