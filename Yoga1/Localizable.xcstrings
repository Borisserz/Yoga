    "pose.seated_twist.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sit with one leg extended, the other foot crossed over the knee."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сядьте, одну ногу вытяните, стопу другой поставьте за колено."
          }
        }
