    "pose.camel.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place your hands on your lower back, fingers down."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Положите ладони на поясницу, пальцами вниз."
          }
