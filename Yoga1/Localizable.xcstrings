    "pose.triangle.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand with feet wide, front foot turned out."
          }
        },
        "ru": {
          "stringUnit": {
