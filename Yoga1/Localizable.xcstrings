    },
    "pose.cobra.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Back bend"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прогиб спины"
          }
        }
      }
    },
    "pose.cobra.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I open my heart"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я раскрываю сердце"
          }
        }
      }
    },
    "pose.cobra.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie face down, legs extended, tops of the feet on the mat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лягте на живот, ноги вытянуты, тыльная сторона стоп на коврике."
          }
        }
      }
    },
    "pose.cobra.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place your hands under your shoulders, elbows close to the body."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поставьте ладони под плечи, локти близко к телу."
          }
        }
      }
    },
    "pose.cobra.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press into your hands and lift your chest on an inhale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На вдохе оттолкнитесь руками и поднимите грудь."
          }
        }
      }
    },
    "pose.cobra.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your shoulders down and away from the ears."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опустите плечи вниз, подальше от ушей."
          }
        }
      }
    },
    "pose.cobra.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lengthen the back of your neck and gaze forward."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вытяните заднюю часть шеи, взгляд вперёд."
          }
        }
      }
    },
    "pose.bridge.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bridge"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поза Моста"
          }
        }
      }
    },
    "pose.bridge.focus": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Glutes & spine"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ягодицы и спина"
          }
        }
      }
    },
    "pose.bridge.mantra": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I lift up"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я поднимаюсь вверх"
          }
        }
      }
    },
    "pose.bridge.step1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie on your back, knees bent, feet hip-width apart."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лягте на спину, колени согнуты, стопы на ширине таза."
          }
        }
      }
    },
    "pose.bridge.step2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place your arms alongside your body, palms down."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Положите руки вдоль тела, ладони вниз."
          }
        }
      }
    },
    "pose.bridge.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press into your feet and lift your hips toward the sky."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оттолкнитесь стопами и поднимите таз вверх."
          }
        }
      }
    },
    "pose.bridge.step4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Roll your shoulders under and clasp your hands if comfortable."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подверните плечи и сцепите ладони, если удобно."
          }
        }
      }
    },
    "pose.bridge.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your knees parallel and breathe steadily."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держите колени параллельно и ровно дышите."
          }
        }
      }
    },
    "pose.cat_cow.name": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cat-Cow"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кошка-Корова"
          }
        }
