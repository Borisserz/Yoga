      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let your arms rest by your sides, palms facing up."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Руки лежат вдоль тела, ладони вверх."
          }
