    "pose.half_moon.step3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift your back leg parallel to the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимите заднюю ногу параллельно полу."
          }
