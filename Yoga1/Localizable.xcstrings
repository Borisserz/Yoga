    "pose.seated_twist.step5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Look over your back shoulder and breathe."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Посмотрите через заднее плечо и дышите."
          }
